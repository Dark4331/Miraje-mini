# ============================================================
# Miraje — environment configuration
# Copy this file to `.env` and adjust. Everything here can also be
# changed at runtime through the in-app Settings panel.
# ============================================================

# --- LLM provider ---
# "openai-compatible" : anything speaking the OpenAI Chat Completions API
#                       (OpenAI, OpenRouter, Together, Groq, LM Studio, vLLM,
#                        llama.cpp server, and Ollama's /v1 endpoint).
# "ollama"             : Ollama's native /api/chat protocol.
MIRAJE_PROVIDER=openai-compatible

# OpenAI-compatible endpoint.
# Examples:
#   Ollama (via OpenAI shim): http://host.docker.internal:11434/v1
#   LM Studio:                http://host.docker.internal:1234/v1
#   llama.cpp server:         http://host.docker.internal:8080/v1
#   OpenAI:                   https://api.openai.com/v1
#   OpenRouter:               https://openrouter.ai/api/v1
MIRAJE_BASE_URL=http://host.docker.internal:11434/v1

# API key. Use any non-empty dummy value for local servers (Ollama, LM Studio).
# For cloud providers, use your real key. Stored only in your local Miraje DB.
MIRAJE_API_KEY=ollama

# Default model name (must exist on your endpoint).
MIRAJE_MODEL=llama3.1

# Native Ollama URL (used only when MIRAJE_PROVIDER=ollama).
MIRAJE_OLLAMA_URL=http://host.docker.internal:11434

# --- Agent behavior ---
MIRAJE_AGENT_MAX_STEPS=12
MIRAJE_AGENT_TEMPERATURE=0.2

# --- Server ---
MIRAJE_HOST=0.0.0.0
MIRAJE_PORT=8000

# --- Privacy (hard-off; exposed for transparency only) ---
MIRAJE_TELEMETRY=false
